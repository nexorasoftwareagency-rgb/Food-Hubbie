# Foodhubbie Firebase Configuration
# ==================================
# Copy this file to .env and fill in your values.
# For the dev Firebase project (food-hubbie), values are available in
# Firebase Console → Project Settings → General → Your apps → Web app.
#
# These are Firebase Web SDK identifiers — they are public-by-design.
# Security is enforced via Security Rules + App Check, not by hiding
# the apiKey. See: https://firebase.google.com/docs/projects/api-keys

FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=1:your-project-id:web:your-web-app-id
FIREBASE_MEASUREMENT_ID=G-YOUR-MEASUREMENT-ID

# reCAPTCHA v3 site key (Firebase App Check)
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
