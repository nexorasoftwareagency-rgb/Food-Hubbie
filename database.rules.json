{
  "rules": {
    /* 
     * ============================================================
     * FOODHUBBIE SAAS — ENTERPRISE SECURITY POLICY v2.0
     * ============================================================
     */

    // 1. MASTER AUTHORIZATION UTILITIES (GLOBAL UNLOCK FOR DISCOVERY)
    ".read": true,
    

    "admins": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('isSuper').val() == true",
      "$uid": {
        // Admins can read their own profile; SuperAdmins can read all
        ".read": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).child('isSuper').val() == true)",
        // Only Master Dev or SuperAdmin can create/modify admin accounts
        ".write": "auth != null && (auth.token.email == 'nexorasoftware@gmail.com' || root.child('admins').child(auth.uid).child('isSuper').val() == true)"
      }
    },

    "riders": {
      // Fleet listing restricted to SuperAdmins or Business Admins
      ".read": "auth != null && (root.child('admins').child(auth.uid).exists())",
      "$uid": {
        // Rider can read/write their own profile (Status, Location, Profile Info)
        ".read": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).exists())",
        
        // SECURE KYC: Only SuperAdmin can approve/reject or modify URLs once set
        "kycStatus": {
          ".write": "auth != null && root.child('admins').child(auth.uid).child('isSuper').val() == true"
        },
        "verified": {
          ".write": "auth != null && root.child('admins').child(auth.uid).child('isSuper').val() == true"
        }
      },
      ".indexOn": ["email", "phone", "businessId"]
    },

    "businesses": {
      // Marketplace and Dashboard need to see businesses
      ".read": true,
      // TEMPORARY: Allow writes for development without Auth session
      ".write": true,

      "$bid": {
        ".read": true,
        ".write": true,

        "outlets": {
          "$oid": {
            ".read": true,
            ".write": true,

            "orders": {
              ".read": true,
              ".write": true,
              "$orderId": {
                ".write": true
              },
              ".indexOn": ["createdAt", "status", "riderId", "phone"]
            },
            
            "inventory": {
              ".read": true,
              ".write": true
            }
          }
        }
      }
    },

    "slugs": {
      "outlets": {
        ".read": true,
        ".write": "auth != null && root.child('admins').child(auth.uid).child('isSuper').val() == true"
      }
    },

    "dishes": {
      ".read": true,
      ".write": true, // TODO: Restrict to Admin Auth in Production
      ".indexOn": ["category", "outlet"]
    },

    "outlets": {
      ".read": true,
      ".write": true, // TODO: Restrict to Admin Auth in Production
      ".indexOn": ["businessId", "name"]
    },

    "bot": {
      "$oid": {
        // Only Admins for this outlet can read bot commands/logs
        ".read": "auth != null && (root.child('admins').child(auth.uid).child('isSuper').val() == true || root.child('admins').child(auth.uid).child('outletId').val() == $oid)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('isSuper').val() == true || root.child('admins').child(auth.uid).child('outletId').val() == $oid)"
      }
    }
  }
}